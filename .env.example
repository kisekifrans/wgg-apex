# Copy to .env.local for local development. On Vercel, add the same keys in Project → Settings → Environment Variables.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PayPal — use sandbox credentials locally; use LIVE credentials + PAYPAL_MODE=live on Vercel Production
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox

# Encrypt predator account credentials at checkout (required in production)
# Generate: openssl rand -base64 32
CHECKOUT_PAYLOAD_ENCRYPTION_KEY=

# Transactional email (Resend) — order confirmations after payment
RESEND_API_KEY=
EMAIL_FROM="WGG Apex <orders@wggapex.com>"
EMAIL_REPLY_TO=support@wggapex.com
# Optional: notify ops on each new paid order
EMAIL_OPS_NOTIFY=support@wggapex.com

# Optional until profiles.role is set in Supabase
ADMIN_EMAILS=

# Optional error monitoring (Sentry) — see docs/STAGING_ENVIRONMENT.md
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Discord marketplace embeds (Admin → listing → Publish to Discord)
DISCORD_MARKETPLACE_WEBHOOK_URL=
DISCORD_MARKETPLACE_SOLD_WEBHOOK_URL=
DISCORD_ORDERS_WEBHOOK_URL=
DISCORD_COMPLETED_BOOSTS_WEBHOOK_URL=
DISCORD_WEBHOOK_USERNAME=WGG Apex
DISCORD_WEBHOOK_AVATAR_URL=
DISCORD_PUBLISH_COOLDOWN_SECONDS=300
DISCORD_OWNER_USER_ID=1119290295281008650

# Homepage Discord panel (required: Server Settings → Widget → Enable Server Widget)
NEXT_PUBLIC_DISCORD_SERVER_ID=
NEXT_PUBLIC_DISCORD_INVITE_URL=
